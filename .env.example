# Copy this file to `.env` in the same folder.
#
# Google Maps — inject at build time (recommended: EAS secrets).
# https://docs.expo.dev/versions/latest/sdk/map-view/#deploy-app-with-google-maps
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# Backend API base URL
EXPO_PUBLIC_API_URL=https://apidev.school2home.in

