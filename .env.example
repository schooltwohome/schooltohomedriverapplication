# Copy this file to `.env` in the same folder.
#
# Google Maps — inject at build time (recommended: EAS secrets).
# https://docs.expo.dev/versions/latest/sdk/map-view/#deploy-app-with-google-maps
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# Backend API base URL
EXPO_PUBLIC_API_URL=https://apidev.school2home.in

# ─── Background location ──────────────────────────────────────────────────────
# No additional env vars needed — background tracking is enabled via app.config.js
# plugins and expo-task-manager. Ensure ACCESS_BACKGROUND_LOCATION is approved in
# the Play Store listing for Android and "Always" location is requested on iOS.
#
# ─── Offline queue ────────────────────────────────────────────────────────────
# AsyncStorage key: @sth:locQueue  (max 500 points, 3 retry attempts per point)
# Install before running: npx expo install @react-native-async-storage/async-storage expo-task-manager

